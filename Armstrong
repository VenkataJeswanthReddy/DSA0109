#include <iostream>
#include <cmath>
using namespace std;
int main() {
    long long n;
    cout << "INPUT: ";
    cin >> n;
    long long temp = n;
    int digits = 0;
    if (temp == 0) digits = 1;
    while (temp != 0) {
        digits++;
        temp /= 10;
    }
    temp = n;
    long long sum = 0;
    while (temp != 0) {
        int digit = temp % 10;
        sum += (long long)pow(digit, digits);
        temp /= 10;
    }
    if (sum == n)
        cout << "OUTPUT: " << n << " is an Armstrong number";
    else
        cout << "OUTPUT: " << n << " is NOT an Armstrong number";

    return 0;
}
