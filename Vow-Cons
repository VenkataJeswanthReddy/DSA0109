#include <iostream>
#include <cctype>
using namespace std;
int main() {
    char ch;
    cin >> ch;
    ch = tolower(static_cast<unsigned char>(ch));
    if (ch >= 'a' && ch <= 'z') {
        if (ch == 'a' || ch == 'e' || ch == 'i' || ch == 'o' || ch == 'u')
            cout << "Vowel";
        else
            cout << "Consonant";
    } else {
        cout << "Invalid input";
    }

    return 0;
}
