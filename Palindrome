#include <iostream>
using namespace std;
int main() {
    int n;
    cin >> n;
    int m = n;
    int rev = 0;
    while (m > 0) {
        int r = m % 10;
        rev = rev * 10 + r;
        m /= 10;
    }
    if (n == rev)
        cout << "number is palindrome";
    else
        cout << "number is not palindrome";
    return 0;
}
